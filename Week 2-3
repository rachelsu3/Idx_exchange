# MORTGAGE RATE ENRICHMENT
# ============================================================================

print("\n" + "="*60)
print("MORTGAGE RATE ENRICHMENT (FRED)")
print("="*60)

# Step 1 – Fetch the mortgage rate data from FRED
print("\nStep 1: Fetching mortgage rate data from FRED...")
url = "https://fred.stlouisfed.org/graph/fredgraph.csv?id=MORTGAGE30US"
mortgage = pd.read_csv(url)

# Check the actual column names
print(f"Columns in FRED data: {mortgage.columns.tolist()}")

# Find the date column (it might be 'DATE', 'observation_date', or something else)
date_col = None
for col in mortgage.columns:
    if 'date' in col.lower():
        date_col = col
        break

if date_col:
    mortgage = mortgage.rename(columns={date_col: 'date'})
    mortgage['date'] = pd.to_datetime(mortgage['date'])
else:
    print("Using first column as date")
    mortgage.columns = ['date', 'rate_30yr_fixed']
    mortgage['date'] = pd.to_datetime(mortgage['date'])

# Find the rate column
rate_col = None
for col in mortgage.columns:
    if 'rate' in col.lower() or 'MORTGAGE' in col:
        rate_col = col
        break

if rate_col:
    mortgage = mortgage.rename(columns={rate_col: 'rate_30yr_fixed'})
else:
    mortgage.columns = ['date', 'rate_30yr_fixed']

print(f"Downloaded {len(mortgage)} weekly records")
print(f"Date range: {mortgage['date'].min()} to {mortgage['date'].max()}")

# Step 2 – Resample weekly rates to monthly averages
print("\nStep 2: Resampling to monthly averages...")
mortgage['year_month'] = mortgage['date'].dt.to_period('M')
mortgage_monthly = mortgage.groupby('year_month')['rate_30yr_fixed'].mean().reset_index()
print(f"Resampled to {len(mortgage_monthly)} monthly records")
print(mortgage_monthly.tail())

# Step 3 – Create a matching year_month key on the MLS datasets
print("\nStep 3: Creating year_month keys...")
# Sold dataset — key off CloseDate
df_sold['year_month'] = pd.to_datetime(df_sold['CloseDate']).dt.to_period('M')
# Listings dataset — key off ListingContractDate
df_listing['year_month'] = pd.to_datetime(df_listing['ListingContractDate']).dt.to_period('M')
print("Year_month keys created for both datasets")

# Step 4 – Merge
print("\nStep 4: Merging mortgage rates...")
sold_with_rates = df_sold.merge(mortgage_monthly, on='year_month', how='left')
listings_with_rates = df_listing.merge(mortgage_monthly, on='year_month', how='left')
print("Merge complete")

# Step 5 – Validate the merge
print("\nStep 5: Validating merge...")
print(f"Null rates in sold data: {sold_with_rates['rate_30yr_fixed'].isnull().sum()}")
print(f"Null rates in listings data: {listings_with_rates['rate_30yr_fixed'].isnull().sum()}")

# Preview
print("\nPreview - Sold data with mortgage rates:")
print(sold_with_rates[['CloseDate', 'year_month', 'ClosePrice', 'rate_30yr_fixed']].head())

# Save enriched datasets
print("\n" + "="*60)
print("SAVE ENRICHED DATASETS")
print("="*60)
