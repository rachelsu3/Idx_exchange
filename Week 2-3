print("="*60)

def analyze_field(df, dataset_name, field):
    if field in df.columns:
        data = df[field].dropna()
        if len(data) > 0:
            print(f"\n{dataset_name} - {field}:")
            print(f"  Count: {len(data):,}")
            print(f"  Mean: {data.mean():,.2f}")
            print(f"  Median: {data.median():,.2f}")
            print(f"  Min: {data.min():,.2f}")
            print(f"  Max: {data.max():,.2f}")
            
            # Percentiles
            pct = data.quantile([0.01, 0.05, 0.25, 0.5, 0.75, 0.95, 0.99])
            print(f"  Percentiles: 1%={pct[0.01]:,.0f}, 5%={pct[0.05]:,.0f}, 25%={pct[0.25]:,.0f}, 50%={pct[0.5]:,.0f}, 75%={pct[0.75]:,.0f}, 95%={pct[0.95]:,.0f}, 99%={pct[0.99]:,.0f}")
            
            # Outliers (3*IQR)
            Q1 = data.quantile(0.25)
            Q3 = data.quantile(0.75)
            IQR = Q3 - Q1
            lower = Q1 - 3*IQR
            upper = Q3 + 3*IQR
            outliers = data[(data < lower) | (data > upper)]
            print(f"  Extreme outliers: {len(outliers)} ({len(outliers)/len(data)*100:.1f}%)")
            return data
    return None

print("\n--- LISTING DATA ---")
for field in market_fields:
    analyze_field(df_listing, "LISTING", field)

print("\n--- SOLD DATA ---")
for field in market_fields:
