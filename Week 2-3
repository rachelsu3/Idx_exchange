# Create a figure with subplots
fig, axes = plt.subplots(len(market_fields), 2, figsize=(12, 4*len(market_fields)))

for i, field in enumerate(market_fields):
    # Get data from either dataframe
    data = None
    if field in df_sold.columns:
        data = df_sold[field].dropna()
    elif field in df_listing.columns:
        data = df_listing[field].dropna()
    
    if data is not None and len(data) > 0:
        # Cap at 99th percentile for better view
        cap = data.quantile(0.99)
        plot_data = data[data <= cap]
        
        # Histogram
        axes[i, 0].hist(plot_data, bins=50, edgecolor='black', alpha=0.7, color='steelblue')
        axes[i, 0].set_title(f'{field} - Histogram')
        axes[i, 0].set_xlabel(field)
        axes[i, 0].set_ylabel('Frequency')
        
        # Boxplot
        axes[i, 1].boxplot(plot_data, vert=True)
        axes[i, 1].set_title(f'{field} - Boxplot')
        axes[i, 1].set_ylabel(field)
    else:
        axes[i, 0].text(0.5, 0.5, f'{field} not found', ha='center', va='center')
        axes[i, 0].set_title(f'{field} - Not Available')
        axes[i, 1].text(0.5, 0.5, f'{field} not found', ha='center', va='center')
        axes[i, 1].set_title(f'{field} - Not Available')

plt.tight_layout()
plt.savefig('distribution_analysis.png', dpi=100, bbox_inches='tight')
print("✓ Visualization saved as 'distribution_analysis.png'")

